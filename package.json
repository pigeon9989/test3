{
  "name": "@pigeon9989/test3-markdown",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 5180",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --passWithNoTests",
    "audit": "pnpm audit --prod --audit-level=high"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.5.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=20.10.0", "pnpm": ">=9.0.0" },
  "packageManager": "pnpm@9.15.0"
}
